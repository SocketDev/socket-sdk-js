{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "pnpm",
        "exec",
        "chrome-devtools-mcp",
        "--isolated",
        "--category-extensions",
        "--no-category-performance",
        "--no-category-emulation"
      ],
      "enabled": true,
      "type": "local"
    },
    "fff": {
      "command": ["fff-mcp"],
      "enabled": true,
      "type": "local"
    },
    "janus-multi": {
      "command": ["node", "scripts/fleet/janus-multi-mcp.mts"],
      "enabled": true,
      "type": "local"
    },
    "linear": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "notion": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "refero": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.refero.design/mcp"
    }
  }
}
