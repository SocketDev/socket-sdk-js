{
  "description": "Fleet guard: block edits to fleet-canonical files. Generated by scripts/fleet/mcp-config.mts.",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node scripts/fleet/cross-cli/pretooluse-hook.mts",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "apply_patch|shell|local_shell"
      }
    ]
  }
}
