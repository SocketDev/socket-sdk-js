{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": false,
  "arrowParens": "avoid",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "singleAttributePerLine": false,
  "ignorePatterns": [
    "**/.cache",
    "**/.claude",
    "**/.DS_Store",
    "**/._.DS_Store",
    "**/.env",
    "**/.git",
    "**/.github",
    "**/.husky",
    "**/.type-coverage",
    "**/.vscode",
    "**/coverage",
    "**/coverage-isolated",
    "**/dist",
    "**/external",
    "**/node_modules",
    "**/package.json",
    "**/pnpm-lock.yaml",
    "**/test/fixtures",
    "**/test/packages"
  ]
}
