# Build-step copies of the vendored acorn artifacts, placed next to the snapshot
# bundle so the acorn-WASM guards resolve ./acorn-bindgen.cjs + ${__dirname}/acorn.wasm
# at runtime (post-deserialize). Regenerated by build-hook-snapshot.mts; source of
# truth is _shared/acorn/.
acorn-bindgen.cjs
acorn.wasm

# Native snapshot launcher: the compiled binary + its build-time-frozen sidecars
# (abs node path + abs blob path) are machine/runtime-specific, regenerated by
# build-snapshot-launcher.mts. Source of truth is dispatch-launcher.c (POSIX) +
# dispatch-launcher-win.c (Windows), both tracked.
dispatch-launcher
dispatch-launcher.exe
node.path
snapshot-blob.path
dispatch-table.mts
